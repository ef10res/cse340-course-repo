<%- include('partials/header') %>

    <main>
        <h1><%= title %></h1>
        <h2>Upcoming Service Projects</h2>
        <% projects.forEach(project=> { %>
            <li>
                <%= project.project_date %>
                <strong>:
                    <%= project.title %>
                </strong>
                <%= project.organization_name %>"
            </li>
            <% }); %>
    </main>
<%- include('partials/footer') %>